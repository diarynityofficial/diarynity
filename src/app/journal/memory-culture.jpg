.journal-detail-card {
  width: min(780px, 100%);
}

.journal-detail-image {
  width: 100%;
  aspect-ratio: 16 / 9;
  margin: 22px 0 28px;
  border-radius: 22px;
  overflow: hidden;
  background: rgba(120, 80, 80, 0.06);
}

.journal-detail-image img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

.journal-detail-body {
  max-width: 680px;
  margin: 0 auto;
}